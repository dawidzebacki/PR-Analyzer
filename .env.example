# Required: GitHub personal access token (raises rate limit from 60 to 5000 req/h).
# Create at https://github.com/settings/tokens — only "public_repo" scope needed.
GITHUB_TOKEN=ghp_your_token_here

# Required: Groq API key for LLM-based PR scoring (llama-3.3-70b-versatile).
# Create at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Optional: canonical site URL for SEO metadata, sitemap, and Open Graph tags.
# On Vercel, falls back to VERCEL_URL if not set. Locally, defaults to http://localhost:3000.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
